# ════════════════════════════════════════════════════════════
#  LINE Bot — 環境變數設定範本
#  使用說明：複製此檔案並重新命名為 .env，填入您的真實金鑰。
#  ⚠️  請絕對不要將含有真實金鑰的 .env 提交到 GitHub！
# ════════════════════════════════════════════════════════════

# ── LINE Messaging API ─────────────────────────────────────
# 從 LINE Developers Console > Messaging API > Channel access token 取得
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN

# 從 LINE Developers Console > Messaging API > Channel secret 取得
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET

# ── OpenAI API ────────────────────────────────────────────
# 從 https://platform.openai.com/api-keys 取得
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# 要使用的 OpenAI 模型（預設 gpt-4o-mini 最省錢、最快）
# 可選值：gpt-4o-mini | gpt-4o | gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# ── Google Sheets ─────────────────────────────────────────
# Google 試算表的 ID（從試算表網址中取得）
# 例如 https://docs.google.com/spreadsheets/d/【這段就是ID】/edit
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID

# 要查詢的工作表名稱（預設：工作表1）
GOOGLE_SHEET_NAME=工作表1

# Google Service Account 的 JSON 憑證（整個 JSON 貼成單行字串）
# 取得方式：GCP Console > IAM > Service Accounts > 建立金鑰 > JSON > 下載
# 然後貼上整個 JSON 內容，例如：{"type":"service_account","project_id":"..."}
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Bot 回覆訊息設定 ──────────────────────────────────────
# 查無檔案時的回覆文字
NOT_FOUND_MESSAGE=找不到您要查詢的檔案，請確認檔名是否正確。
