# ════════════════════════════════════════════════════════════
#  LINE Bot — Premium Features Replacement
#  環境變數設定範本（複製此檔並重新命名為 .env，填入真實金鑰）
#  ⚠️  .env 已被 .gitignore 保護，請勿刪除該設定！
# ════════════════════════════════════════════════════════════

# ── 🟢 必填：LINE Messaging API ───────────────────────────
# 從 LINE Developers Console > Messaging API 取得
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET

# ── 🟢 必填：OpenAI API ──────────────────────────────────
# 從 https://platform.openai.com/api-keys 取得
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# 使用的 AI 模型（預設 gpt-4o-mini，最省錢）
# 可選：gpt-4o-mini | gpt-4o | gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# ── 🟢 必填：Google Sheets（檔案查詢用）────────────────
# 試算表 ID（從網址 /spreadsheets/d/【這段】/edit 取得）
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID

# 工作表名稱（預設：工作表1）
GOOGLE_SHEET_NAME=工作表1

# Google Service Account JSON 字串
# 取得方式：GCP Console > IAM > Service Accounts > 建立金鑰 > JSON
# 複製整個 JSON 內容貼成單行字串（含大括號）
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_PROJECT",...}

# ── 🔵 選填：Google Drive 媒體備份目標資料夾 ID ─────────
# 若不填，收到圖片/影片時將不會進行備份
# 取得方式：在 Google Drive 開啟目標資料夾，網址最後一段即為 Folder ID
# 記得讓 Service Account 的 Email 對此資料夾有「編輯者」權限！
GOOGLE_DRIVE_FOLDER_ID=

# ── 🔵 選填：Langfuse AI 觀測儀表板 ─────────────────────
# 前往 https://cloud.langfuse.com 免費註冊，在 Settings > API Keys 取得
# 若不填，機器人仍可正常運作，只是沒有 AI 呼叫追蹤功能
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── 🔵 選填：多輪對話記憶設定 ────────────────────────────
# 每位使用者保留最近幾輪對話作為上下文（預設 10 輪）
MEMORY_WINDOW=10

# SQLite 記憶資料庫路徑（Zeabur 建議保持 /tmp/ 路徑）
MEMORY_DB_PATH=/tmp/linebot_memory.db

# ── 🔵 選填：機器人回覆訊息設定 ─────────────────────────
NOT_FOUND_MESSAGE=找不到您要查詢的檔案，請確認檔名是否正確。

# ── 🔵 選填：Threads API（發文/數據/關鍵字搜尋）──────────────
# 需要到 Meta Developers 申請 Threads API 權限並取得 Access Token
# 注意：若要使用「關鍵字搜尋」功能，Access Token 需包含 threads_keyword_search 權限
THREADS_ACCESS_TOKEN=
# 你的 Threads User ID（抓自己貼文/insights 會用到）
THREADS_USER_ID=
